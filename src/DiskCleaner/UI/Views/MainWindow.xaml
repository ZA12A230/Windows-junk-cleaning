<Window x:Class="DiskCleaner.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="DiskCleaner" Width="1000" Height="700" WindowStartupLocation="CenterScreen">
    <TabControl>
        <TabItem Header="清理"><Frame x:Name="CleanFrame" NavigationUIVisibility="Hidden"/></TabItem>
        <TabItem Header="卸载"><Frame x:Name="UninstallFrame" NavigationUIVisibility="Hidden"/></TabItem>
        <TabItem Header="设置"><Frame x:Name="SettingsFrame" NavigationUIVisibility="Hidden"/></TabItem>
    </TabControl>
</Window>
