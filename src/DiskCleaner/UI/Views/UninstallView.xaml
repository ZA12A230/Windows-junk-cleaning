<Page
    x:Class="DiskCleaner.UI.Views.UninstallView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DiskCleaner.UI.ViewModels"
    xmlns:models="using:DiskCleaner.Models">
    
    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <Button 
                Content="刷新列表"
                Command="{x:Bind ((vm:UninstallViewModel)Resources.ViewModel).LoadSoftwareListCommand}"/>
            <Button 
                Content="导出 CSV"
                Command="{x:Bind ((vm:UninstallViewModel)Resources.ViewModel).ExportToCsvCommand}"/>
            <Button 
                Content="卸载选中"
                Command="{x:Bind ((vm:UninstallViewModel)Resources.ViewModel).UninstallSelectedCommand}"
                Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>
        
        <!-- 软件列表 -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ((vm:UninstallViewModel)Resources.ViewModel).SoftwareList, Mode=OneWay}"
            SelectedItem="{x:Bind ((vm:UninstallViewModel)Resources.ViewModel).SelectedSoftware, Mode=TwoWay}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="名称" Width="250">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:InstalledSoftware">
                                <TextBlock Text="{x:Bind DisplayName}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="发布者" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:InstalledSoftware">
                                <TextBlock Text="{x:Bind Publisher}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="版本" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:InstalledSoftware">
                                <TextBlock Text="{x:Bind DisplayVersion}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="大小" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:InstalledSoftware">
                                <TextBlock Text="{x:Bind FormattedSize}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="安装日期" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:InstalledSoftware">
                                <TextBlock Text="{x:Bind InstallDate}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        
        <!-- 状态栏 -->
        <TextBlock 
            Grid.Row="2"
            Text="{x:Bind ((vm:UninstallViewModel)Resources.ViewModel).StatusText, Mode=OneWay}"
            Margin="0,10,0,0"/>
    </Grid>
</Page>
