<Page
    x:Class="DiskCleaner.UI.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DiskCleaner.UI.ViewModels">
    
    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>
    
    <ScrollViewer Margin="20">
        <StackPanel Width="500">
            <TextBlock Text="扫描设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <CheckBox Content="扫描垃圾文件" IsChecked="{Binding ScanJunkFiles}" Margin="0,0,0,10"/>
            <CheckBox Content="扫描不常用文件" IsChecked="{Binding ScanUnusedFiles}" Margin="0,0,0,10"/>
            <CheckBox Content="扫描大文件" IsChecked="{Binding ScanLargeFiles}" Margin="0,0,0,10"/>
            <CheckBox Content="扫描不重要文件" IsChecked="{Binding ScanUnimportantFiles}" Margin="0,0,0,10"/>
            
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="不常用文件判定天数 (天)"/>
                <TextBox Text="{Binding UnusedDaysThreshold}" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>
            
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="大文件阈值 (MB)"/>
                <TextBox Text="{Binding LargeFileSizeThreshold}" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>
            
            <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" 
                    Width="120" HorizontalAlignment="Left" Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
