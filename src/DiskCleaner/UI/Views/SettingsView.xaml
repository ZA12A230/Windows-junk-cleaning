<Page
    x:Class="DiskCleaner.UI.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DiskCleaner.UI.ViewModels">
    
    <ScrollViewer Padding="20">
        <StackPanel Spacing="20" MaxWidth="600">
            <TextBlock Text="扫描设置" FontSize="20" FontWeight="SemiBold"/>
            
            <ToggleSwitch 
                Header="扫描垃圾文件"
                IsOn="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).ScanJunkFiles, Mode=TwoWay}"/>
            
            <ToggleSwitch 
                Header="扫描不常用文件"
                IsOn="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).ScanUnusedFiles, Mode=TwoWay}"/>
            
            <ToggleSwitch 
                Header="扫描大文件"
                IsOn="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).ScanLargeFiles, Mode=TwoWay}"/>
            
            <ToggleSwitch 
                Header="扫描不重要文件"
                IsOn="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).ScanUnimportantFiles, Mode=TwoWay}"/>
            
            <StackPanel>
                <TextBlock Text="不常用文件判定天数 (天)"/>
                <NumberBox 
                    Value="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).UnusedDaysThreshold, Mode=TwoWay}"
                    Minimum="1"
                    Maximum="365"
                    SpinButtonPlacementMode="Inline"/>
            </StackPanel>
            
            <StackPanel>
                <TextBlock Text="大文件阈值 (MB)"/>
                <NumberBox 
                    Value="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).LargeFileSizeThreshold, Mode=TwoWay}"
                    Minimum="100"
                    Maximum="10240"
                    SpinButtonPlacementMode="Inline"/>
            </StackPanel>
            
            <TextBlock Text="界面设置" FontSize="20" FontWeight="SemiBold" Margin="0,20,0,0"/>
            
            <ComboBox 
                Header="语言"
                SelectedItem="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).SelectedLanguage, Mode=TwoWay}">
                <x:String>zh-CN</x:String>
                <x:String>en-US</x:String>
            </ComboBox>
            
            <ComboBox 
                Header="主题"
                SelectedItem="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).SelectedTheme, Mode=TwoWay}">
                <x:String>Auto</x:String>
                <x:String>Light</x:String>
                <x:String>Dark</x:String>
            </ComboBox>
            
            <Button 
                Content="保存设置"
                Command="{x:Bind ((vm:SettingsViewModel)Resources.ViewModel).SaveSettingsCommand}"
                HorizontalAlignment="Left"
                Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
