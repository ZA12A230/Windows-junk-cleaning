<Page
    x:Class="DiskCleaner.UI.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ScrollViewer Margin="20">
        <StackPanel Width="500">
            <TextBlock Text="扫描设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <CheckBox x:Name="JunkFilesCheck" Content="扫描垃圾文件" IsChecked="True" Margin="0,0,0,10"/>
            <CheckBox x:Name="UnusedFilesCheck" Content="扫描不常用文件" IsChecked="True" Margin="0,0,0,10"/>
            <CheckBox x:Name="LargeFilesCheck" Content="扫描大文件" IsChecked="True" Margin="0,0,0,10"/>
            <CheckBox x:Name="UnimportantFilesCheck" Content="扫描不重要文件" IsChecked="True" Margin="0,0,0,10"/>
            
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="不常用文件判定天数 (天)"/>
                <TextBox x:Name="UnusedDaysText" Text="90" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>
            
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="大文件阈值 (MB)"/>
                <TextBox x:Name="LargeSizeText" Text="500" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>
            
            <Button x:Name="SaveBtn" Content="保存设置" Width="120" HorizontalAlignment="Left" Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
