<Page
    x:Class="DiskCleaner.UI.Views.CleanView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DiskCleaner.UI.ViewModels"
    xmlns:models="using:DiskCleaner.Models">
    
    <Page.Resources>
        <vm:CleanViewModel x:Key="ViewModel"/>
    </Page.Resources>
    
    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <Button 
                Content="开始扫描"
                Command="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).StartScanCommand}"
                IsEnabled="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).IsScanning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                Width="120"/>
            
            <Button 
                Content="取消"
                Command="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).CancelScanCommand}"
                IsEnabled="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).IsScanning, Mode=OneWay}"
                Width="80"/>
            
            <Button 
                Content="清理选中"
                Command="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).CleanSelectedCommand}"
                IsEnabled="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).CanClean, Mode=OneWay}"
                Width="120"/>
            
            <Button 
                Content="清理全部"
                Command="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).CleanAllCommand}"
                IsEnabled="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).CanClean, Mode=OneWay}"
                Width="120"/>
        </StackPanel>
        
        <!-- 进度条 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <TextBlock 
                Text="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).ScanProgressText, Mode=OneWay}"
                VerticalAlignment="Center"/>
            <ProgressBar 
                Value="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).ScanProgressValue, Mode=OneWay}"
                Width="200"/>
        </StackPanel>
        
        <!-- 文件列表 -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).Files, Mode=OneWay}"
            SelectedItem="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).SelectedFile, Mode=TwoWay}"
            Margin="0,0,0,20">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="文件名" Width="300">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:FileEntry">
                                <TextBlock Text="{x:Bind FileName}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="大小" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:FileEntry">
                                <TextBlock Text="{x:Bind FormattedSize}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="类型" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:FileEntry">
                                <TextBlock Text="{x:Bind FileType}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="路径" Width="400">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:FileEntry">
                                <TextBlock Text="{x:Bind Directory}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="最后访问" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate x:DataType="models:FileEntry">
                                <TextBlock Text="{x:Bind LastAccessTime:Format='yyyy-MM-dd HH:mm'}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        
        <!-- 底部状态栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="20">
            <TextBlock>
                <Run Text="总计:"/>
                <Run Text="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).TotalCount, Mode=OneWay}"/>
                <Run Text="个文件,"/>
                <Run Text="{x:Bind ((vm:CleanViewModel)Resources.ViewModel).TotalSize, Mode=OneWay, Converter={StaticResource FileSizeConverter}}"/>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
