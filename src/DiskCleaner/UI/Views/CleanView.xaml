<Page
    x:Class="DiskCleaner.UI.Views.CleanView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DiskCleaner.UI.ViewModels"
    xmlns:models="clr-namespace:DiskCleaner.Models">
    
    <Page.DataContext>
        <vm:CleanViewModel/>
    </Page.DataContext>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="开始扫描" Command="{Binding StartScanCommand}" Width="120" Margin="0,0,10,0"/>
            <Button Content="取消" Command="{Binding CancelScanCommand}" Width="80" Margin="0,0,10,0"/>
            <Button Content="清理选中" Command="{Binding CleanSelectedCommand}" Width="120" Margin="0,0,10,0"/>
            <Button Content="清理全部" Command="{Binding CleanAllCommand}" Width="120"/>
        </StackPanel>
        
        <!-- 文件列表 -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Files}" 
                  SelectedItem="{Binding SelectedFile}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="0,0,0,20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="250"/>
                <DataGridTextColumn Header="大小" Binding="{Binding FormattedSize}" Width="100"/>
                <DataGridTextColumn Header="类型" Binding="{Binding FileType}" Width="100"/>
                <DataGridTextColumn Header="路径" Binding="{Binding Directory}" Width="400"/>
                <DataGridTextColumn Header="最后访问" Binding="{Binding LastAccessTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- 状态栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock>
                <Run Text="总计:"/>
                <Run Text="{Binding TotalCount}"/>
                <Run Text="个文件,"/>
                <Run Text="总计:"/>
                <Run Text="{Binding TotalSize}"/>
                <Run Text="bytes"/>
            </TextBlock>
        </StackPanel>
        
        <!-- 进度条 -->
        <ProgressBar Grid.Row="2" Value="{Binding ScanProgressValue}" Maximum="100" Height="20" 
                     Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</Page>
