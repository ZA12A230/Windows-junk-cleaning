<Window x:Class="DiskCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiskCleaner"
        xmlns:vm="clr-namespace:DiskCleaner.ViewModels"
        mc:Ignorable="d"
        Title="Windows 系统清理工具" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1E293B" Offset="0.5"/>
                <GradientStop Color="#0F172A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource LiquidGlassBrush}" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Windows 系统清理工具" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="深度清理 · 智能扫描 · 安全卸载" 
                               FontSize="14" 
                               Foreground="#E2E8F0" 
                               Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="全选" Style="{StaticResource ModernButton}" 
                            Command="{Binding SelectAllCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="取消全选" Style="{StaticResource ModernButton}" 
                            Background="{StaticResource SecondaryColor}"
                            Command="{Binding DeselectAllCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Scan Options -->
            <Border Grid.Column="0" 
                    Background="#1E293B" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="扫描选项" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="0,0,0,20"/>
                    
                    <CheckBox Content="临时文件" 
                              IsChecked="{Binding ScanTempFiles}"
                              Foreground="#E2E8F0"
                              FontSize="14"
                              Margin="0,0,0,15"/>
                    
                    <CheckBox Content="回收站" 
                              IsChecked="{Binding ScanRecycleBin}"
                              Foreground="#E2E8F0"
                              FontSize="14"
                              Margin="0,0,0,15"/>
                    
                    <CheckBox Content="浏览器缓存" 
                              IsChecked="{Binding ScanBrowserCache}"
                              Foreground="#E2E8F0"
                              FontSize="14"
                              Margin="0,0,0,30"/>
                    
                    <Button Content="开始扫描" 
                            Style="{StaticResource ModernButton}"
                            FontSize="16"
                            Padding="30,15"
                            Command="{Binding StartScanCommand}"/>
                    
                    <Button Content="清理选中" 
                            Style="{StaticResource ModernButton}"
                            Background="{StaticResource AccentColor}"
                            FontSize="16"
                            Padding="30,15"
                            Margin="0,15,0,0"
                            Command="{Binding CleanFilesCommand}"/>
                </StackPanel>
            </Border>
            
            <!-- Right Panel - File List -->
            <Border Grid.Column="1" 
                    Background="#1E293B" 
                    CornerRadius="12" 
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="扫描结果" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="0,0,0,15"/>
                    
                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding Files}"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="选择" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="文件名" Width="300" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="大小" Width="100" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                <GridViewColumn Header="类型" Width="120" DisplayMemberBinding="{Binding Type}"/>
                            </GridView>
                        </ListView.View>
                        
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="border" 
                                                    Background="Transparent" 
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="6">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#334155"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="#1E293B" Padding="20">
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="#94A3B8" 
                       FontSize="14"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
