<Window x:Class="SystemCleanerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SystemCleanerPro.ViewModels"
        Title="SystemCleanerPro"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#1E1E32" CornerRadius="16" BorderBrush="#1AFFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0F0F1A" CornerRadius="16,16,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2D5AFC" Offset="0"/>
                                    <GradientStop Color="#00D9FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="SystemCleanerPro" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="—" Width="36" Height="36" Click="MinimizeButton_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="16"/>
                        <Button Content="□" Width="36" Height="36" Click="MaximizeButton_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="14" Margin="4,0"/>
                        <Button Content="✕" Width="36" Height="36" Click="CloseButton_Click" Style="{StaticResource DangerButtonStyle}" Padding="0" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GlassBorderStyle}" Margin="8" CornerRadius="12">
                    <StackPanel Margin="8">
                        <TextBlock Text="功能菜单" Foreground="#B0B0C0" FontSize="12" Margin="16,8,16,16"/>

                        <RadioButton x:Name="NavJunk" GroupName="Nav" Style="{StaticResource NavButtonStyle}" 
                                     IsChecked="True" Checked="Nav_Checked" Tag="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑️" FontSize="16" Margin="0,0,12,0"/>
                                <TextBlock Text="垃圾清理"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavUnused" GroupName="Nav" Style="{StaticResource NavButtonStyle}" 
                                     Checked="Nav_Checked" Tag="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="16" Margin="0,0,12,0"/>
                                <TextBlock Text="不常用文件"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavLarge" GroupName="Nav" Style="{StaticResource NavButtonStyle}" 
                                     Checked="Nav_Checked" Tag="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="16" Margin="0,0,12,0"/>
                                <TextBlock Text="大文件"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavUnimportant" GroupName="Nav" Style="{StaticResource NavButtonStyle}" 
                                     Checked="Nav_Checked" Tag="3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="16" Margin="0,0,12,0"/>
                                <TextBlock Text="不重要文件"/>
                            </StackPanel>
                        </RadioButton>

                        <Separator Margin="16,16" Background="#1AFFFFFF"/>

                        <RadioButton x:Name="NavUninstall" GroupName="Nav" Style="{StaticResource NavButtonStyle}" 
                                     Checked="Nav_Checked" Tag="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="16" Margin="0,0,12,0"/>
                                <TextBlock Text="软件卸载"/>
                            </StackPanel>
                        </RadioButton>

                        <Separator Margin="16,16" Background="#1AFFFFFF"/>

                        <Button Content="开始扫描" Style="{StaticResource PrimaryButtonStyle}" 
                                Margin="8,8" Click="StartScan_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource GlassBorderStyle}" Margin="0,8,8,8" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1">
                            <Grid Margin="16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="CategoryTitle" Text="垃圾文件" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="FileCountText" Text=" (0 个文件)" Foreground="#B0B0C0" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <ComboBox x:Name="DeleteModeCombo" Width="140" Margin="0,0,8,0" SelectedIndex="0">
                                        <ComboBoxItem Content="移动到回收站"/>
                                        <ComboBoxItem Content="永久删除"/>
                                        <ComboBoxItem Content="强力删除"/>
                                    </ComboBox>
                                    <Button Content="全选" Style="{StaticResource SecondaryButtonStyle}" Padding="16,8" Click="SelectAll_Click"/>
                                    <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}" Padding="16,8" Margin="8,0,0,0" Click="DeselectAll_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ListView x:Name="FileListView" Grid.Row="1" 
                                  Background="Transparent" BorderThickness="0"
                                  Margin="8" SelectionMode="Extended"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="" Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="名称" Width="280">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FileName}" Foreground="White" TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="路径" Width="350">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DirectoryPath}" Foreground="#B0B0C0" TextTrimming="CharacterEllipsis" ToolTip="{Binding DirectoryPath}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="大小" Width="100">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FormattedSize}" Foreground="#00D9FF" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="类型" Width="100">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Extension}" Foreground="#B0B0C0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="访问时间" Width="140">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FormattedLastAccess}" Foreground="#B0B0C0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2D5AFC"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2A4A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <ListView x:Name="SoftwareListView" Grid.Row="1" 
                                  Background="Transparent" BorderThickness="0"
                                  Margin="8" Visibility="Collapsed">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="" Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="软件名称" Width="300">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="版本" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Version}" Foreground="#B0B0C0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="发布者" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Publisher}" Foreground="#B0B0C0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="大小" Width="100">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FormattedSize}" Foreground="#00D9FF" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2D5AFC"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2A4A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#0F0F1A" CornerRadius="0,0,16,16">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                            <TextBlock Text="总计: " Foreground="#B0B0C0" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalFilesText" Text="0 个文件" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalSizeText" Text=" (0 B)" Foreground="#00D9FF" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="已选: " Foreground="#B0B0C0" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SelectedFilesText" Text="0 个文件" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SelectedSizeText" Text=" (0 B)" Foreground="#2ED573" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ProgressBar x:Name="ScanProgress" Width="200" Height="8" 
                                     Style="{StaticResource ProgressBarStyle}"
                                     Visibility="Collapsed"/>
                        <TextBlock x:Name="StatusText" Text="就绪" Foreground="#B0B0C0" FontSize="12" 
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <Button x:Name="CleanButton" Content="开始清理" Style="{StaticResource PrimaryButtonStyle}" 
                                Margin="16,0,0,0" Click="Clean_Click"/>
                        <Button x:Name="UninstallButton" Content="深度卸载" Style="{StaticResource DangerButtonStyle}" 
                                Margin="8,0,0,0" Click="Uninstall_Click" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
